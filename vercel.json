{
  "version": 2,
  "public": true,
  "builds": [
    {
      "src": "artifacts/music-player/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://CHANGE_ME_TO_RAILWAY_URL/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/music-player/$1"
    }
  ],
  "cleanUrls": true
}
