{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["artifacts/api-server/**", "lib/**"]
  },
  "deploy": {
    "startCommand": "cd artifacts/api-server && npm run start",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  }
}
